# Copy to .env and fill in values:  cp .env.example .env
# Do not commit .env (it is gitignored).

# --- LLM (OpenAI-compatible: OpenAI, Groq, etc.) ---
OPENAI_API_KEY=
# Optional: Groq, vLLM, LiteLLM proxy, etc.
OPENAI_BASE_URL=
# Chat model name (must match your provider)
MEM0_CHAT_MODEL=llama-3.1-8b-instant

# --- Local embedder (HuggingFace / sentence-transformers) ---
MEM0_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
MEM0_EMBEDDING_DIMS=768
# Set to 1 only if the model is already cached and you want fully offline runs
HF_HUB_OFFLINE=0

# --- Qdrant local path mode (no Qdrant server) ---
QDRANT_PATH=./qdrant_storage
QDRANT_COLLECTION_NAME=pdc_baseline_mem_v4
# Default 1 for interactive_rag.py: skip BM25/fastembed ONNX (can hard-crash Python on Windows). Dense semantic search still runs.
MEM0_CLI_DISABLE_BM25=1

# --- Session ---
MEM0_USER_ID=cli_user
